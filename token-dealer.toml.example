# ── Per-tier routing. `tier/model` syntax in client requests also works
#    and bypasses this entirely (single-model pass-through). ────────────
[tiers.simple]
primary = "anthropic/claude-haiku-4-5"
allow_tier_downgrade = false
[tiers.simple.timeouts]
connect_ms = 5000
read_ms = 15000
per_attempt_ms = 20000

[tiers.standard]
primary = "anthropic/claude-sonnet-4-5"
allow_tier_downgrade = true
downgrade_to = "simple"
[tiers.standard.timeouts]
connect_ms = 8000
read_ms = 30000
per_attempt_ms = 45000

[tiers.complex]
primary = "anthropic/claude-opus-4-5"
allow_tier_downgrade = true
downgrade_to = "standard"
[tiers.complex.timeouts]
connect_ms = 8000
read_ms = 45000
per_attempt_ms = 90000

[tiers.reasoning]
primary = "anthropic/claude-opus-4-5"
allow_tier_downgrade = false
[tiers.reasoning.timeouts]
connect_ms = 10000
read_ms = 120000
per_attempt_ms = 180000

[tiers.high_context]
primary = "anthropic/claude-sonnet-4-5"
allow_tier_downgrade = false
min_context_window = 100000
[tiers.high_context.timeouts]
connect_ms = 10000
read_ms = 60000
per_attempt_ms = 300000

[tiers.multimodal]
primary = "anthropic/claude-sonnet-4-5"
allow_tier_downgrade = false
[tiers.multimodal.timeouts]
connect_ms = 15000
read_ms = 60000
per_attempt_ms = 120000

[detection]
default_tier = "standard"
session_window_minutes = 30
session_lookback = 5

[retry]
max_same_provider_retries = 1
fixed_retry_wait_ms = 1500
max_retry_after_ms = 10000
request_budget_ms = 120000

[streaming]
buffer_threshold_tokens = 2048

# ── Specificity routing ─────────────────────────────────────────────────
# Detects the *type* of task in each request (coding, web_browsing,
# data_analysis, image_generation, video_generation, social_media,
# email_management, calendar_management, trading) and routes to a
# per-category primary model instead of the tier's default. Inspired
# by mnfst/manifest's specificity system. Disabled by default.
#
# [specificity]
# enabled = true
# rules = [
#   { category = "coding",            primary = "anthropic/claude-sonnet-4-5" },
#   { category = "data_analysis",    primary = "anthropic/claude-opus-4-5"   },
#   { category = "image_generation",  primary = "openai/gpt-image-1"          },
# ]
#
# Override the per-category default threshold (weighted keyword
# matches + tool-name prefixes required to fire). Default thresholds
# are tuned conservatively to avoid false positives.
# { category = "coding", primary = "x/y", threshold = 3 }
#
# Per-request override header:
#   X-Router-Specificity: coding

# ── Cost budgets ────────────────────────────────────────────────────────
# Hard caps enforced before each request. 0 = unlimited. Returns
# HTTP 429 with `error.code = budget_exceeded` when a cap is hit.
#
# [budgets]
# daily_cost_usd      = 50.0    # total spend across the day (UTC)
# per_request_cost_usd = 1.0    # max USD per single request
# warn_fraction       = 0.8     # soft-warning threshold fraction

# ── OpenRouter pricing sync ─────────────────────────────────────────────
# Free, no-auth JSON catalog of 300+ model prices at
# https://openrouter.ai/api/v1/models. Background task refreshes
# the `model_prices` table on startup + every `interval_hours`.
#
# [pricing_sync]
# enabled        = true
# interval_hours = 24
# openrouter_url  = "https://openrouter.ai/api/v1/models"

# ── Model discovery ─────────────────────────────────────────────────────
# On startup, fetch `/v1/models` from each connected provider and
# cache the model list in the `provider_models` table. Powers the
# `/v1/models` listing + tier auto-assignment.
#
# [discovery]
# enabled                  = true
# auto_assign_tiers        = false   # auto-fill empty tier primaries from discovered models
# min_input_price_per_1m   = 0.10    # skip ultra-cheap (likely low-quality) models
