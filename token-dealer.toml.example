# token-dealer — example config
# Copy to token-dealer.toml and edit, or mount as TOKEN_DEALER_CONFIG.
#
# All 28 provider types manifest supports are pre-defined with sensible
# base URLs + paths. To enable a provider, uncomment its block and set
# the API key (or rely on the {PROVIDER}_API_KEY env var). Unconfigured
# providers are not registered; you only pay for what you wire up.

[server]
bind = "0.0.0.0:8080"
log_level = "info"
# For OAuth popup flows — must be publicly reachable from the
# user's browser. The test deployment is at 100.99.145.19:18080.
oauth_redirect_uri = "http://100.99.145.19:18080/admin/oauth/openai/callback"

[database]
path = "/data/router.db"

[auth]
enabled = false

# ── Wire formats with their own adapters ─────────────────────────────
[[providers]]
id = "anthropic"
type = "anthropic"
key = "${ANTHROPIC_API_KEY}"
default_model = "claude-sonnet-4-5"
# base_url + path filled from manifest defaults; override here for staging.

# [[providers]]
# id = "google"
# type = "google"
# key = "${GEMINI_API_KEY}"

# [[providers]]
# id = "kiro"
# type = "kiro"
# key = "${KIRO_API_KEY}"

# [[providers]]
# id = "responses"
# type = "responses"
# key = "${OPENAI_API_KEY}"
# Use for o1-pro, codex, deep-research.

# ── OpenAI-compat providers (use OpenAI adapter with provider base URL) ──
[[providers]]
id = "openai"
type = "openai"
key = "${OPENAI_API_KEY}"
default_model = "gpt-4o-mini"

